#!/bin/sh

set -eu

repo_root=$(git rev-parse --show-toplevel)

echo "pre-push: running make format"
make -C "$repo_root" format

if ! git -C "$repo_root" diff --quiet -- src; then
  echo "pre-push: formatting changed tracked files under src/." >&2
  echo "pre-push: review the changes, stage them, and create a new commit before pushing." >&2
  git -C "$repo_root" --no-pager diff --stat -- src >&2
  exit 1
fi

echo "pre-push: formatting check passed"

echo "pre-push: building LaTeX report"
cd $repo_root/docs/report && make ci-check
echo "pre-push: report build passed"
cd -

echo "pre-push: building doxygen docs"
make -C "$repo_root" doxygen
echo "pre-push: doxygen build passed"
